# Qwen / DashScope API Key
# Get from: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=Place your actual api key
# Database
# Local dev: leave as default (SQLite)
# Production: switch to ApsaraDB RDS PostgreSQL URL
DATABASE_URL=sqlite+aiosqlite:///./demo_data/chartpilot_demo.db

# App settings
APP_ENV=development
SECRET_KEY=change-this-to-a-random-secret-in-production
ALLOWED_ORIGINS=http://localhost:5173

# NDPR Audit
AUDIT_LOG_ENABLED=true